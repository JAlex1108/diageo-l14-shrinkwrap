# --- Virtual environments ---
diageo_env/
.venv/
venv/
env/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# --- Video source + clips (large binaries — never commit) ---
*.ts
*.mp4
*.avi
*.mkv
*.mov
*.webm

# --- Generated pipeline outputs / artefacts ---
# Every analysis folder keeps its generated artefacts in its own output/ folder.
# (Tracked result images that were git-mv'd into an output/ folder stay tracked —
# gitignore only hides new files.)
output/
*.zip

# NOTE: AnomalyDetection/phase_anchor_41884872.png is intentionally NOT ignored — the
# anomaly script needs it, so it is tracked (only ~1.8 MB).

# --- Raw data / example footage ---
ShrinkWrapClassification/failure_mode_examples/

# --- DataFiles ---
docs/tasks/*
*.csv
*.pdf

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
