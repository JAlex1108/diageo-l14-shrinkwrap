# CSV files are kept local by default.
# These four working areas are the exception because their notebooks and analyses
# need committed CSVs alongside the code.
*.csv
!measurements/
!measurements/**/*.csv
!stop_clip_anomaly_detection/
!stop_clip_anomaly_detection/**/*.csv
!video_coverage_log/
!video_coverage_log/**/*.csv
!stoppage_detection/
!stoppage_detection/**/*.csv

# Video files stay local everywhere in the repo.
videos/
*.mp4
*.ts
*.avi
*.mov
*.mkv
# Image files
*.png
*.jpg
*.jpeg
*.bmp

# ...except README doc assets (committed example plots referenced from READMEs)
!docs/
!docs/**/*.png

# Model weights and checkpoints
models/
*.pt
*.pth
*.onnx
*.pb
*.h5
*.weights

# Data directories
# (the old top-level data/ = OD training output was moved to output/od_runs/ in task 65;
#  output/ is already ignored below, so od_runs/ is covered.)
# Generated/curated datasets (synthetic clips, diageo_cortex_worst, video sets) are
# large, locally reproducible data — the whole tree is kept local, never committed.
datasets/
# MCP / tooling scratch (Playwright MCP page snapshots, etc.)
.playwright-mcp/
patchcore_test_videos/
Results/
TestData/
output/
# Anomaly-detection run outputs (anomaly clips/frames/grids/summaries) — derived,
# regenerable from the pipeline; the per-run summary JSON is a local readback.
anomaly_out/
# Raw key-frame image captures (Hangzhou line) — image data, kept local
Hangzou_key_frames/
# Keyframe-extraction / reference-match script outputs (matched frames, ROI grids) —
# derived image data, regenerable from the scripts; kept local.
matched keyframes/
# (the old repo-root nestle/ demo set + glass_breakage/ raw captures were moved into
#  datasets/ in task 65 — datasets/* already ignores them there.)

# Generated debug artifacts (grids, signals, scratch readbacks) — derived,
# regenerable; the whole folder is kept local, never committed.
debug_output/

# Local experimental scratch code (not part of the shipped module)
sandbox/

# scripts/ — the local "lab bench": standalone drivers, one-off experiments, and
# operational CLIs that sit OUTSIDE the importable VideoModule package. Kept on disk
# (downloaders, the per-site keyframe-extraction CLIs + configs) but no longer tracked
# — the shipped capability lives in VideoModule/ and experiments/. The synthetic-data
# generators moved to experiments/datasets/synthetic/demo_clips/ (tracked).
# EXCEPTION: two modules the shipped fewshot-labelling pipeline still imports
# (encode_326_changepoint_raw + its vendored real_clip_method_compare front-end) stay
# tracked until they are relocated into VideoModule — that edit touches pipeline files
# currently owned by an in-flight refactor in another session. See scripts/README.md.
scripts/
!scripts/encoding/
!scripts/encoding/encode_326_changepoint_raw.py
!scripts/evaluation/
!scripts/evaluation/real_clip_method_compare.py

# (labels_processed.csv moved into datasets/video/labelled_326/ in task 65 — ignored via datasets/*)

# Research corpus (literature .md files, kept local, not committed)
research/

